# === Obsidian Sync ===
OBSIDIAN_AUTH_TOKEN=<token-from-ob-login>

# === Azure OpenAI ===
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_TRANSCRIPTION_DEPLOYMENT=whisper-1
# AZURE_OPENAI_API_VERSION=  # Optional — omit to use the v1 GA default

# === Telegram ===
TELEGRAM_BOT_TOKEN=<token-from-botfather>
TELEGRAM_AUTHORIZED_USERS=your_username

# === Agent ===
LOG_LEVEL=INFO
LLM_MAX_TOKENS=4096
USER_TIMEZONE=Europe/Rome

# === URL Extraction ===
URL_EXTRACTION_ENABLED=true
URL_EXTRACTOR_BACKEND=crawl4ai
URL_EXTRACTION_MAX_URLS_PER_MESSAGE=3
URL_FETCH_TIMEOUT_SECONDS=25
URL_FETCH_MAX_CHARS=12000
URL_ALLOW_PRIVATE_NETS=false
URL_ALLOWED_DOMAINS=
URL_BLOCKED_DOMAINS=
LINK_NOTES_FOLDER=Links
ATTACHMENTS_FOLDER=Attachments
